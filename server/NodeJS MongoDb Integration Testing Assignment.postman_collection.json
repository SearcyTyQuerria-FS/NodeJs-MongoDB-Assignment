              "});",
              "",
              "// Test successful execution",
              "pm.test(\"Response indicates update was successful\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "//  Test that the payload reflects the new changes",
              "pm.test(\"Room number and discharge status are updated\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.roomNumber).to.eql(205);",
              "    pm.expect(jsonData.data.isDischarged).to.be.true;",
              "});"
