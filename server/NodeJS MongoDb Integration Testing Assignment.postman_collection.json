    {
      "name": "get patient by id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//  Test the status code",
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test the payload validation",
              "pm.test(\"Returned patient matches the requested ID\", function () {",
              "    var jsonData = pm.response.json();",
              "    var savedId = pm.collectionVariables.get(\"patientId\");",
              "    pm.expect(jsonData.data._id).to.eql(savedId);",
              "});",
              "",
              "// Test data integrity",
              "pm.test(\"Payload includes required schema fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property(\"dateOfBirth\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
