  "item": [
    {
      "name": "Create Patient",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test the status code",
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// Test the payload structure",
              "pm.test(\"Response has success: true and returns patient data\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property(\"fullName\", \"Jane Doe\");",
              "});",
              "",
              "// Test default schema values & Save ID for future tests",
              "pm.test(\"isDischarged defaults to false\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.isDischarged).to.be.false;",
              "",
              "    // extracts the ID and saves it so the next tests can use it automatically",
              "    if(jsonData.data && jsonData.data._id) {",
              "        pm.collectionVariables.set(\"patientId\", jsonData.data._id);",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"dateOfBirth\": \"1985-06-15\",\n  \"roomNumber\": 101\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
